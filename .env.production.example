# =============================================================
#  AI JOB PLATFORM — Production Environment Template
#  Copy to .env.prod on your server. NEVER commit real values.
# =============================================================

# ── App ────────────────────────────────────────────────────────
NODE_ENV=production
APP_URL=https://yourdomain.com
API_URL=https://api.yourdomain.com
AI_SERVICE_URL=http://ai-service:8000
INTERNAL_API_URL=http://api:4000

# ── Database ───────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/ai_job_platform?schema=public&sslmode=require"
POSTGRES_DB=ai_job_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://:PASSWORD@HOST:6379
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Auth (JWT) — must be >= 64 chars ──────────────────────────
JWT_SECRET=CHANGE_ME_AT_LEAST_64_CHARS_RANDOM_STRING_HERE_EXAMPLE
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_64_CHAR_RANDOM_STRING_EXAMPLE
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
NEXTAUTH_SECRET=CHANGE_ME_RANDOM_STRING
NEXTAUTH_URL=https://yourdomain.com

# ── Encryption ─────────────────────────────────────────────────
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX_OR_RANDOM_STRING_HERE

# ── Google OAuth ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://api.yourdomain.com/api/v1/auth/google/callback

# ── LinkedIn OAuth ─────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=https://api.yourdomain.com/api/v1/auth/linkedin/callback

# ── File Storage (AWS S3) ─────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name
# AWS_ENDPOINT=  (leave blank for real S3; set for MinIO)
AWS_PUBLIC_URL=https://your-bucket-name.s3.us-east-1.amazonaws.com
AWS_PRESIGN_URL=https://your-bucket-name.s3.us-east-1.amazonaws.com

# ── AI / OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# ── Stripe Billing ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_ANNUAL=price_xxx

# ── Email (SendGrid) ──────────────────────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-api-key
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=AI Job Platform

# ── Observability ─────────────────────────────────────────────
SENTRY_DSN=https://xxx@oXXXXXX.ingest.sentry.io/XXXXXXX
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=ai-job-platform

# ── Automation ────────────────────────────────────────────────
BROWSER_POOL_SIZE=3
AUTOMATION_RATE_LIMIT_MS=3000
PLAYWRIGHT_HEADLESS=true

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── Registry (for docker-compose.prod.yml) ────────────────────
REGISTRY=ghcr.io/your-org
VERSION=latest

# ── Netlify (frontend) ─────────────────────────────────────────
# Set NEXT_PUBLIC_APP_URL to your Netlify URL after first deploy
NEXT_PUBLIC_APP_URL=https://YOUR_SITE.netlify.app
INTERNAL_API_URL=https://aijob-api.onrender.com   # Render API URL

# ── Render (backend) ──────────────────────────────────────────
# Add RENDER_DEPLOY_HOOK_API and RENDER_DEPLOY_HOOK_WORKER
# in GitHub Secrets for automated deploys from CI/CD
# RENDER_DEPLOY_HOOK_API=https://api.render.com/deploy/srv-XXX?key=YYY
# RENDER_DEPLOY_HOOK_WORKER=https://api.render.com/deploy/srv-XXX?key=YYY

# ── Timeouts & Performance ────────────────────────────────────
APPLY_TIMEOUT_MS=180000

