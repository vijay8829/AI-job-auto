# =============================================================================
# AI JOB AUTOMATION PLATFORM — PRODUCTION ENVIRONMENT TEMPLATE
# =============================================================================
# Copy to .env.prod and fill in ALL values before deploying.
# NEVER commit this file with real values.
# =============================================================================

# ─── Node ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ─── URLs ────────────────────────────────────────────────────────────────────
# Frontend public URL (used for CORS, OAuth redirects, Stripe success URL)
APP_URL=https://yourdomain.com
# Admin panel URL (if separate)
ADMIN_URL=https://admin.yourdomain.com
# Internal API URL used by Next.js SSR rewrites (within Docker network)
INTERNAL_API_URL=http://api:4000
# Public-facing API URL used by the browser
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ─── Database ────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public&sslmode=require
DATABASE_URL=postgresql://postgres:CHANGEME@your-db-host:5432/ai_job_platform?schema=public&sslmode=require
POSTGRES_DB=ai_job_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGEME_STRONG_PASSWORD

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGEME_REDIS_PASSWORD@your-redis-host:6379
REDIS_PASSWORD=CHANGEME_REDIS_PASSWORD

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGEME_64_CHAR_HEX_STRING
JWT_REFRESH_SECRET=CHANGEME_DIFFERENT_64_CHAR_HEX_STRING
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
# AES-256 key for credential encryption — generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGEME_64_CHAR_HEX_STRING

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret
GOOGLE_CALLBACK_URL=https://yourdomain.com/api/v1/auth/google/callback

# ─── AWS S3 / MinIO ──────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=ai-job-platform-resumes
# For AWS S3 leave AWS_ENDPOINT blank; for MinIO set to internal URL
AWS_ENDPOINT=
# Browser-accessible URL for presigned downloads
AWS_PUBLIC_URL=https://your-bucket.s3.us-east-1.amazonaws.com

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_CHANGEME
STRIPE_WEBHOOK_SECRET=whsec_CHANGEME
STRIPE_PRO_PRICE_ID=price_CHANGEME_pro_monthly
STRIPE_ENTERPRISE_PRICE_ID=price_CHANGEME_enterprise_monthly

# ─── Sentry ──────────────────────────────────────────────────────────────────
SENTRY_DSN=https://your-key@sentry.io/project-id
NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/project-id
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=ai-job-platform

# ─── AI Service ──────────────────────────────────────────────────────────────
# Internal Docker network address
AI_SERVICE_URL=http://ai-service:8000

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── SendGrid (email notifications) ─────────────────────────────────────────
SENDGRID_API_KEY=SG.CHANGEME
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=AI Job Platform

# ─── Automation ──────────────────────────────────────────────────────────────
BROWSER_POOL_SIZE=3
PLAYWRIGHT_HEADLESS=true
AUTOMATION_RATE_LIMIT_MS=3000
# Max ms to wait for a single apply-to-job run before killing it (default 3 min)
APPLY_TIMEOUT_MS=180000
WORKER_PORT=4001

# ─── Docker Registry (for docker-compose.prod.yml) ───────────────────────────
REGISTRY=ghcr.io/your-github-username
VERSION=latest
